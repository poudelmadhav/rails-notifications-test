<% content_for :title, "Showing user" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing user</h1>

  <%= render @user %>

  <div class="mt-6" data-controller="fcm-token" data-fcm-token-user-id-value="<%= @user.id %>">
    <h2 class="font-bold text-2xl mb-3">Notification Tokens</h2>

    <button type="button" data-action="fcm-token#register"
            class="mb-4 rounded-md px-3 py-2 bg-green-600 text-white text-sm hover:bg-green-500 cursor-pointer">
      Register browser for push notifications
    </button>

    <% if @user.notification_tokens.any? %>
      <ul class="mb-4 space-y-2">
        <% @user.notification_tokens.each do |token| %>
          <li class="flex items-center gap-2 text-sm">
            <span class="font-mono truncate max-w-xs"><%= token.token %></span>
            <span class="px-2 py-0.5 bg-gray-100 rounded text-xs"><%= token.platform %></span>
            <%= button_to "Remove", user_notification_token_path(@user, token), method: :delete,
                  class: "text-red-500 hover:text-red-700 text-xs cursor-pointer" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500 mb-4">No tokens registered yet.</p>
    <% end %>

    <details class="mb-4">
      <summary class="cursor-pointer text-sm text-blue-600 hover:text-blue-800">Register a token manually</summary>
      <%= form_with model: [@user, NotificationToken.new], local: true, class: "mt-3 flex gap-2" do |f| %>
        <%= f.text_field :token, placeholder: "FCM device token", required: true,
              class: "flex-1 rounded-md border-gray-300 px-3 py-2 text-sm" %>
        <%= f.select :platform, options_for_select(NotificationToken.platforms.map { |k, _| [k.humanize, k] }),
              {}, class: "rounded-md border-gray-300 px-3 py-2 text-sm" %>
        <%= f.submit "Register", class: "rounded-md px-3 py-2 bg-blue-600 text-white text-sm hover:bg-blue-500 cursor-pointer" %>
      <% end %>
    </details>
  </div>

  <%= link_to "Edit this user", edit_user_path(@user), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to users", users_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= button_to "Destroy this user", @user, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>
